{
  "name": "ghostfolio-agent",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "vite build",
    "start": "node dist/server/main.js",
    "dev": "tsx watch src/server/main.ts",
    "dev:client": "vite",
    "test": "jest --runInBand",
    "evals": "tsx src/server/evals/run-evals.ts --set golden",
    "evals:golden": "tsx src/server/evals/run-evals.ts --set golden",
    "evals:scenarios": "tsx src/server/evals/run-evals.ts --set scenarios",
    "evals:all": "tsx src/server/evals/run-evals.ts --set all"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@langfuse/otel": "^4.6.1",
    "@langfuse/tracing": "^4.6.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.97.0",
    "big.js": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "langsmith": "^0.5.6",
    "plaid": "^41.3.0",
    "yahoo-finance2": "^2.14.0"
  },
  "devDependencies": {
    "@types/big.js": "^6.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.18.0",
    "jest": "^30.1.3",
    "js-yaml": "^4.1.1",
    "prisma": "^5.22.0",
    "ts-jest": "^29.4.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^6.0.1"
  }
}
