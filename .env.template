PORT=3334
CORS_ORIGIN=http://localhost:5179
# Ghostfolio API base URL (no trailing slash). Use production URL when Ghostfolio is deployed.
GHOSTFOLIO_API_URL=
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-sonnet-4-20250514
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.2
AGENT_DEFAULT_LOOKBACK_DAYS=30
AGENT_ALLOW_EDU=true
AGENT_DEFAULT_ACCOUNT_ID=
AGENT_ENABLE_MARKET=false
AGENT_VALUATION_FALLBACK=cost_basis

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ghostfolio-agent

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Supabase (multi-user auth + database) ──
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Client-side Supabase env vars (Vite injects these at build time)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Google OAuth ──
# To enable Google sign-in (fixes "missing OAuth secret" and "Error 400: redirect_uri_mismatch"):
# 1. Get your Supabase callback URL: Supabase Dashboard → Project Settings → API → Project URL.
#    If Project URL is https://xyz123.supabase.co then callback = https://xyz123.supabase.co/auth/v1/callback
# 2. In Google Cloud Console → APIs & Services → Credentials → your OAuth 2.0 Web client:
#    - Authorized JavaScript origins: your app only (e.g. http://localhost:5179, https://app.ghostfolioapp.com)
#    - Authorized redirect URIs: ONLY the Supabase callback from step 1 (e.g. https://xyz123.supabase.co/auth/v1/callback).
#      Do NOT put http://localhost:5179 here — Google redirects to Supabase first, so the URI must be the Supabase URL. Wrong URI = redirect_uri_mismatch.
# 3. Supabase Dashboard → Authentication → Providers → Google: enable, set Client ID + Client Secret.
# 4. Supabase Dashboard → Authentication → URL Configuration → Redirect URLs: add where users land after login (e.g. http://localhost:5179, https://app.ghostfolioapp.com).
# No env vars in this repo — Supabase stores the secret; only VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are needed client-side.

# ── Ghostfolio Internal (self-hosted on Railway) ──
# Internal URL for Railway service-to-service communication
GHOSTFOLIO_INTERNAL_URL=
# Admin access token for creating new Ghostfolio users programmatically (required for portfolio data)
GHOSTFOLIO_ADMIN_TOKEN=
# If you see "connection issue" or empty portfolio: ensure GHOSTFOLIO_API_URL is reachable from this server and GHOSTFOLIO_ADMIN_TOKEN is set. Sign in once so your Ghostfolio account is provisioned.

# ── Plaid (brokerage connectivity) ──
# Get credentials at https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── Supabase + Prisma (database) ──
# Supabase pooler URL (Transaction mode) — used by Prisma at runtime
DATABASE_URL=
# Supabase direct URL — used by Prisma for migrations only
DIRECT_URL=

# ── Token encryption ──
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Golden set evals (npm run evals). Optional if running evals with env vars on CLI.
EVAL_BASE_URL=http://localhost:3334
EVAL_JWT=
